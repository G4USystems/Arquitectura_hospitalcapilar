# =============================================
# Hospital Capilar Platform - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# =============================================
# PostHog Analytics
# =============================================
# Get your API key from: https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=phc_your_project_api_key_here

# PostHog host (EU or US)
# EU: https://eu.i.posthog.com
# US: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# =============================================
# PostHog API (for Dashboard - optional)
# =============================================
# Personal API key for accessing PostHog API
# Get it from: https://app.posthog.com/me/settings
VITE_POSTHOG_PROJECT_API_KEY=phx_your_personal_api_key_here

# Your PostHog project ID (number from URL)
VITE_POSTHOG_PROJECT_ID=12345

# =============================================
# Firebase (optional - for storing leads)
# =============================================
# Get these from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
